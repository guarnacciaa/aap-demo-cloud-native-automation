# ============================================================================
# DEMO CONFIGURATION VARIABLES (EXAMPLE)
# ============================================================================
# Copy to demo_variables.yml and edit for your environment.
# demo_variables.yml is gitignored so it is not overwritten on git pull.
#
# This file is organized into two scopes, marked by the banners below:
#   [ALWAYS REQUIRED]  needed in every deployment, regardless of mode.
#   [LAB/DEV ONLY]      consumed exclusively by the Setup - */Teardown - *
#                       job templates and workflows. SKIP these entire
#                       sections when demo_manage_infrastructure is false
#                       (customer/PoC deployment against pre-existing
#                       infrastructure) — leaving them at their defaults is
#                       fine, they are simply never used.
# playbooks/aap_config.yml and playbooks/verify.yml enforce this: the
# [LAB/DEV ONLY] variables are only validated when demo_manage_infrastructure
# is true, so a customer/PoC deployment is never blocked by them.
# ============================================================================

demo_no_log: false
# Unmask errors from infra.aap_configuration roles (credentials, etc.).
# Set to true in production to hide secrets from job output.
aap_configuration_secure_logging: false

# --- Deployment mode --- [ALWAYS REQUIRED]
# true (default): lab / dev / self-demo deployment. CasC creates the full
#   infrastructure lifecycle: Setup - Azure runbook, Setup - AWS SSM
#   resources, Teardown - Azure runbook, Teardown - AWS SSM resources, plus
#   the WF - Demo setup and WF - Demo teardown workflows. Use this when
#   there is no pre-existing Azure Automation Account or AWS SSM target and
#   you want the demo to create and destroy everything itself. All
#   [LAB/DEV ONLY] variables below must be set.
# false: customer / PoC deployment against pre-existing infrastructure. CasC
#   creates ONLY the scenario job templates (Azure - Run Runbook and collect
#   output, Azure - Schedule Runbook, AWS - Run SSM document and collect
#   output, AWS - Schedule SSM via maintenance window, Notify - Email
#   automation results, plus the dry-run templates) and their workflows. No
#   provisioning or teardown objects are created in AAP at all, which
#   removes any risk of accidentally launching a job that creates a
#   duplicate Automation Account or tears down the customer's existing SSM
#   target. [LAB/DEV ONLY] variables below can be left at their defaults.
demo_manage_infrastructure: true

# ============================================================================
# Vault variable mappings [ALWAYS REQUIRED]
# ============================================================================
# Map vault_ prefixed secrets to the plain names used by roles and playbooks.
# vault.yml must be copied from vault.yml.example and encrypted before use.
controller_username: "{{ vault_controller_username }}"
controller_password: "{{ vault_controller_password }}"
azure_client_id: "{{ vault_azure_client_id }}"
azure_client_secret: "{{ vault_azure_client_secret }}"
aws_access_key: "{{ vault_aws_access_key }}"
aws_secret_key: "{{ vault_aws_secret_key }}"
smtp_password: "{{ vault_smtp_password }}"

# --- AAP connection --- [ALWAYS REQUIRED]
# controller_username and controller_password are mapped from vault above.
# The dispatch role resolves gateway auth from aap_* -> controller_* fallback.
aap_hostname: CHANGE_ME
aap_username: "{{ controller_username }}"
aap_password: "{{ controller_password }}"
aap_validate_certs: false

# Controller REST API path prefix when calling through Platform Gateway (AAP 2.5+).
# Do not use legacy /api/v2/ on the gateway hostname.
aap_controller_api_prefix: /api/controller/v2

# --- AAP object names --- [ALWAYS REQUIRED]
demo_organization_name: Cloud Native Automation Demo
demo_organization_description: Azure Runbook and AWS SSM automation PoC
demo_project_name: Cloud Native Automation Demo
demo_label_name: cloud-native-automation
demo_inventory_name: Demo-CloudNativeAutomation
# Child inventory names — must be unique across artifacts, not the bare
# "Azure-Resources"/"AWS-Resources" shape. ansible.controller.host and
# ansible.controller.group resolve their inventory: parameter by name only,
# with no organization filter (module.resolve_name_to_id), so a same-named
# inventory in another artifact's Organization makes aap_config.yml fail with
# "returned 2 items, expected 1". See artifact--demo-variables.mdc.
demo_azure_inventory_name: Azure-Resources-CloudNativeAutomation
demo_aws_inventory_name: AWS-Resources-CloudNativeAutomation
demo_execution_environment_name: ee-cloud-native-automation

# Full image reference after building and pushing to Private Automation Hub.
# Replace CHANGE_ME with your PAH hostname (e.g. hub.example.com).
demo_execution_environment_image: CHANGE_ME/ee-cloud-native-automation:latest

# Private Automation Hub container registry (for Controller EE image pulls). [ALWAYS REQUIRED if using a custom EE]
# Use the Gateway host or IP without a URL scheme; must match demo_execution_environment_image.
hub_registry_credential_name: PAH Container Registry - Cloud Native Automation
hub_registry_host: "{{ aap_hostname | regex_replace('^https?://', '') | regex_replace('/$', '') }}"

# ============================================================================
# Git repository configuration [ALWAYS REQUIRED]
# ============================================================================
# Choose ONE of the following options based on your Git hosting platform:
#
# OPTION A: GitHub
#   demo_project_scm_url: https://github.com/YOUR_USERNAME/aap-demo-cloud-native-automation.git
#
# OPTION B: Gitea (self-hosted)
#   demo_project_scm_url: https://your-gitea.example.com/YOUR_USERNAME/aap-demo-cloud-native-automation.git
#
# OPTION C: GitLab
#   demo_project_scm_url: https://gitlab.com/YOUR_USERNAME/aap-demo-cloud-native-automation.git
# ============================================================================

demo_project_scm_url: CHANGE_ME_GIT_REPO_URL
demo_project_scm_branch: main

# ============================================================================
# AWS SSM settings [ALWAYS REQUIRED]
# ============================================================================
# Consumed by the scenario job templates in every deployment mode. In
# customer/PoC mode (demo_manage_infrastructure: false), these variables
# must identify the customer's EXISTING SSM Automation document (and,
# when relevant, an EXISTING SSM-managed instance).

aws_region: us-east-1
# aws_access_key and aws_secret_key are mapped from vault above.
# Name of the SSM Automation document. Bring-your-own: must match a
# pre-existing document. Create-from-scratch: 02_aws_setup.yml creates it
# with this name.
aws_ssm_document_name: aap-demo-ssm-document
# OPTIONAL — leave empty ("") when the Automation document does not target
# an SSM-managed instance. Set it when the document runs aws:runCommand
# steps against an EC2 host via the SSM agent:
#   Bring-your-own: ID of the pre-existing SSM-managed instance to target.
#   Create-from-scratch: populated after running 02_aws_setup.yml — copy the
#   printed EC2 instance ID here.
# Leave empty for documents that orchestrate AWS API calls directly
# (aws:executeAwsApi, aws:invokeLambdaFunction, etc.) instead of running
# commands on an instance — for example a document whose real target is an
# EKS cluster. In that case, supply the document's actual parameters via
# aws_ssm_document_parameters below instead.
aws_ssm_target_instance_id: ""

# Extra parameters passed to start-automation-execution / the maintenance
# window task, as a list of "Key=Value" strings (AWS CLI shorthand syntax).
# Combined with InstanceId above when aws_ssm_target_instance_id is set.
# Required when the document's target is not an EC2 instance, e.g.:
#   aws_ssm_document_parameters:
#     - "ClusterName=my-eks-cluster"
aws_ssm_document_parameters: []

# --- AWS SSM maintenance window ---
# Bring-your-own: ID of the pre-existing maintenance window to target.
# Create-from-scratch: populated after running 02_aws_setup.yml — copy the
# printed window ID here.
aws_ssm_maintenance_window_id: CHANGE_ME
aws_ssm_maintenance_task_name: aap-demo-ssm-task
# IAM role ARN that SSM assumes to execute the maintenance window Automation task.
# Bring-your-own mode: supply the ARN of a pre-existing role with
#   AmazonSSMAutomationRole (or equivalent ssm:StartAutomationExecution permissions).
# Create-from-scratch mode (aws_create_network_resources: true): 02_aws_setup.yml
#   creates the role and prints its ARN — copy the printed value here.
aws_ssm_service_role_arn: CHANGE_ME_ROLE_ARN
# 12-digit AWS account ID — used to build the SSM automation-definition ARN.
# 02_aws_setup.yml always retrieves and prints this value via STS; copy it here.
# Retrieve manually with: aws sts get-caller-identity --query Account --output text
aws_account_id: CHANGE_ME

# ============================================================================
# Azure Automation settings [ALWAYS REQUIRED]
# ============================================================================
# Consumed by the scenario job templates in every deployment mode. In
# customer/PoC mode (demo_manage_infrastructure: false), azure_automation_resource_group
# and azure_automation_account must name the customer's EXISTING Automation Account.

# Authentication mode for every Azure Automation REST API call (token
# acquisition in azure_runbook_run.yml, azure_runbook_schedule.yml,
# 01_azure_setup.yml, 01_azure_teardown.yml, and the dry-run playbooks). Two
# values:
#   service_principal (default): azure_client_id + azure_client_secret +
#     azure_tenant_id (mapped from vault above) are exchanged for a Resource
#     Manager access token via an OAuth2 client-credentials POST. Works
#     regardless of where AAP itself is hosted — the correct choice for
#     customer/PoC deployments and the only choice if AAP does not run on Azure.
#   msi: Managed Identity. No client secret stored anywhere; the token is
#     instead requested from the Azure Instance Metadata Service (IMDS)
#     endpoint (http://169.254.169.254/metadata/identity/oauth2/token).
#     Requires the AAP execution node/EE container that runs the job to
#     itself be an Azure resource (VM, VMSS, AKS node, etc.) with a system-
#     or user-assigned identity enabled and the same RBAC role granted (see
#     docs/setup.md). azure_client_id/azure_client_secret are then unused
#     (leave the vault entries at CHANGE_ME).
azure_auth_mode: service_principal

azure_subscription_id: CHANGE_ME
azure_tenant_id: CHANGE_ME
# azure_client_id and azure_client_secret are mapped from vault above.
# Only used when azure_auth_mode: service_principal (see above).

# Resource group and account names used in both modes.
# Bring-your-own: must match names of pre-existing Azure resources.
# Create-from-scratch (azure_create_automation_account: true, see the
#   [LAB/DEV ONLY] section below): 01_azure_setup.yml creates resources with
#   these names; replace CHANGE_ME with desired names (e.g. aap-demo-cna-rg,
#   aap-demo-automation).
azure_automation_resource_group: CHANGE_ME
azure_automation_account: CHANGE_ME

# Name of the runbook. Bring-your-own: must match a pre-existing runbook.
# Create-from-scratch: created by playbooks/setup/01_azure_setup.yml.
azure_runbook_name: aap-demo-runbook

# --- Azure runbook schedule ---
azure_job_schedule_name: poc-runbook-schedule
# ISO 8601 UTC timestamp for the first scheduled execution.
azure_schedule_start_time: "2026-06-15T02:00:00Z"
azure_schedule_frequency: Hour
azure_schedule_interval: 24

# ============================================================================
# Optional email notification [ALWAYS REQUIRED if enable_email_notification: true]
# ============================================================================
# Requires community.general collection (no certified SMTP module available).
# Set enable_email_notification: true and configure SMTP details below.

enable_email_notification: false
smtp_host: smtp.example.com
smtp_port: 587
smtp_username: notifier@example.com
# smtp_password is mapped from vault at the top of this file.
notification_to: ops@example.com
# Used by both notify_results.yml (secure: starttls) and the
# Notify - SMTP preflight check (dry run) job template. Set to false only
# for a relay that never uses STARTTLS on this port.
smtp_use_tls: true
# Used only by the Notify - SMTP preflight check (dry run) job template.
# notify_results.yml's community.general.mail module never validates the
# server certificate on STARTTLS (a Python smtplib default outside this
# module's control), so this only affects the precheck. Set to false when
# the relay's certificate CN/SAN does not match smtp_host (common on
# corporate relays reached through a load balancer or internal DNS alias)
# to keep the precheck's pass/fail outcome consistent with what the real
# send in notify_results.yml will actually do.
smtp_validate_certs: true

# ============================================================================
# Credential names (must match credentials.yml) [ALWAYS REQUIRED]
# ============================================================================
# Must be unique across artifacts, not a generic placeholder like "Azure
# Service Principal": job_template's credentials: list resolves each name via
# a name-only Controller API lookup with no organization filter
# (module.resolve_name_to_id), so a same-named credential in another
# artifact's Organization makes aap_config.yml fail with
# "returned 2 items, expected 1". See artifact--demo-variables.mdc.

azure_credential_name: Azure Service Principal - Cloud Native Automation
aws_credential_name: AWS IAM User - Cloud Native Automation
# Custom "SMTP Credentials" credential type (see credential_types.yml) that
# injects smtp_username/smtp_password as extra_vars at run time, so the
# password is never stored in plaintext on the Notify job templates.
smtp_credential_name: SMTP Notification Credentials

# ============================================================================
# Azure — Automation Account provisioning [LAB/DEV ONLY]
# Consumed exclusively by Setup - Azure runbook / Teardown - Azure runbook.
# Leave at defaults when demo_manage_infrastructure: false; they are unused.
# ============================================================================
# Two modes controlled by azure_create_automation_account:
#   false (default) — bring-your-own: azure_automation_resource_group and
#                     azure_automation_account (above) must name pre-existing
#                     resources.
#   true            — create-from-scratch: 01_azure_setup.yml creates the
#                     resource group and Automation Account from scratch
#                     using the location/SKU below.
#                     Teardown counterpart (01_azure_teardown.yml) removes
#                     all resources created in this mode.
azure_create_automation_account: false

# Location and SKU for resources provisioned by 01_azure_setup.yml.
# Safe to leave as-is; customize only if defaults conflict with your environment.
azure_resource_group_location: eastus
azure_automation_account_sku: Basic

# Description used only when 01_azure_setup.yml creates the runbook object.
azure_runbook_description: AAP cloud-native automation demo runbook

# ============================================================================
# AWS — networking, IAM, and EC2 provisioning [LAB/DEV ONLY]
# Consumed exclusively by Setup - AWS SSM resources / Teardown - AWS SSM resources.
# Leave at defaults when demo_manage_infrastructure: false; they are unused.
# ============================================================================
# These variables are consumed by the setup playbooks that provision supporting
# infrastructure before the demo scenario can run. Run setup playbooks in order:
#   01_azure_setup.yml → 02_aws_setup.yml → aap_config.yml

# --- EC2 networking and IAM mode ---
# false (default): supply IDs for pre-existing resources in the bring-your-own
#                  section below. No VPC or IAM objects are created.
# true:            02_aws_setup.yml creates a VPC, subnet, internet gateway,
#                  route table, security group, IAM role, and instance profile
#                  from scratch. Use this when no suitable network exists yet.
aws_create_network_resources: false

# --- EC2 target instance (02_aws_setup.yml) ---
# Use an Amazon Linux 2023 or RHEL AMI with SSM agent pre-installed.
aws_ec2_instance_name: aap-demo-ssm-target
aws_ec2_instance_type: t3.micro
aws_ec2_ami_id: CHANGE_ME
# SSH key pair name — optional; omit (or leave CHANGE_ME) for SSM-only access.
aws_ec2_key_name: CHANGE_ME

# --- Bring-your-own network (aws_create_network_resources: false) ---
# Supply IDs for pre-existing resources. These variables are ignored when
# aws_create_network_resources is set to true.
aws_ec2_vpc_subnet_id: CHANGE_ME
aws_ec2_security_group_ids:
  - CHANGE_ME
# IAM instance profile that grants the EC2 instance AmazonSSMManagedInstanceCore.
# Create this profile in IAM before running 02_aws_setup.yml.
aws_ec2_iam_instance_profile: CHANGE_ME
# Set true when the bring-your-own subnet is a public subnet and you want the
# instance to receive a public IP. The ec2_instance module does not always inherit
# the subnet's map_public_ip_on_launch attribute at launch time.
# In create-from-scratch mode this is always true (the setup playbook creates a
# public subnet with an internet gateway); this variable has no effect in that mode.
aws_ec2_assign_public_ip: false

# --- Create-from-scratch network (aws_create_network_resources: true) ---
# Names and CIDR blocks for resources provisioned by 02_aws_setup.yml.
# Safe to leave as-is; customize only if the defaults conflict with your environment.
# Teardown counterpart (02_aws_teardown.yml) removes all resources created here.
aws_vpc_name: aap-demo-cna-vpc
aws_vpc_cidr: "10.0.0.0/16"
aws_subnet_name: aap-demo-cna-subnet
aws_subnet_cidr: "10.0.1.0/24"
aws_sg_name: aap-demo-cna-sg
# IAM role and instance profile created by 02_aws_setup.yml (profile name = role name).
aws_iam_role_name: aap-demo-ssm-instance-role
# IAM service role created by 02_aws_setup.yml for SSM maintenance window task execution.
# SSM assumes this role (trust: ssm.amazonaws.com) to run Automation documents on the
# EC2 target. AmazonSSMAutomationRole managed policy is attached automatically.
# After setup, copy the printed ARN into aws_ssm_service_role_arn above.
aws_ssm_service_role_name: aap-demo-ssm-service-role

# --- AWS maintenance window (02_aws_setup.yml) ---
demo_aws_maintenance_window_name: aap-demo-maintenance-window
# Cron or rate expression; default: every Sunday at 02:00 UTC.
demo_aws_maintenance_window_schedule: "cron(0 2 ? * SUN *)"
